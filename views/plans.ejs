<% layout("layouts/boilerplate") %>
<body>
  <section class="py-5">
    <div class="text-center mb-5">
      <h1 class="fw-bold display-5 mb-3">
        Plans Designed for Every Stage of Life
      </h1>

      <p class="lead text-muted col-lg-7 mx-auto">
        Every individual and family has unique financial goals. Explore our
        broad categories of insurance solutions and choose the protection that
        suits your needs.
      </p>
    </div>

    <div class="row g-4">
      <div class="col-lg-6">
        <div class="card border-0 shadow-sm rounded-4 h-100">
          <div class="card-body p-5">
            <div class="mb-4 fs-1">🛡️</div>

            <h3 class="fw-bold mb-3">Protection Plans</h3>

            <p class="text-muted mb-4">
              Ensure financial security for your loved ones with comprehensive
              life protection solutions.
            </p>

            <p class="mb-0">
              <strong>Suitable for:</strong>
              Family breadwinners and individuals seeking long-term protection.
            </p>
          </div>
        </div>
      </div>

      <div class="col-lg-6">
        <div class="card border-0 shadow-sm rounded-4 h-100">
          <div class="card-body p-5">
            <div class="mb-4 fs-1">👶</div>

            <h3 class="fw-bold mb-3">Child Education Plans</h3>

            <p class="text-muted mb-4">
              Plan today for your child's education and future milestones with
              disciplined financial planning.
            </p>

            <p class="mb-0">
              <strong>Suitable for:</strong>
              Parents planning for their children's future needs.
            </p>
          </div>
        </div>
      </div>

      <div class="col-lg-6">
        <div class="card border-0 shadow-sm rounded-4 h-100">
          <div class="card-body p-5">
            <div class="mb-4 fs-1">👴</div>

            <h3 class="fw-bold mb-3">Retirement Plans</h3>

            <p class="text-muted mb-4">
              Build a retirement corpus that helps you maintain financial
              independence and peace of mind.
            </p>

            <p class="mb-0">
              <strong>Suitable for:</strong>
              Working professionals and business owners.
            </p>
          </div>
        </div>
      </div>

      <div class="col-lg-6">
        <div class="card border-0 shadow-sm rounded-4 h-100">
          <div class="card-body p-5">
            <div class="mb-4 fs-1">💰</div>

            <h3 class="fw-bold mb-3">Savings & Investment Plans</h3>

            <p class="text-muted mb-4">
              Achieve your long-term financial goals through disciplined savings
              while enjoying insurance protection.
            </p>

            <p class="mb-0">
              <strong>Suitable for:</strong>
              Individuals seeking wealth creation and financial security.
            </p>
          </div>
        </div>
      </div>
    </div>

    <div class="text-center py-5 mt-5 bg-light rounded-4">
      <h2 class="fw-bold mb-3">Not Sure Which Plan Is Right for You?</h2>

      <p class="text-muted col-lg-7 mx-auto mb-4">
        Choosing an insurance plan depends on your age, financial
        responsibilities, and future goals. Get personalized guidance to find
        the solution that best suits you and your family.
      </p>

      <a href="/consult" class="btn btn-primary btn-lg px-4">
        Get Free Consultation
      </a>
    </div>
  </section>
</body>
