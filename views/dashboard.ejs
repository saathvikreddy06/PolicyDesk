<% layout("layouts/boilerplate") %>
<body>
  <section class="py-5">
    <div class="mb-5">
      <h1 class="fw-bold">Welcome, P. Gopal Reddy 👋</h1>

      <p class="text-muted">
        Manage customers, policies, and consultation requests from one place.
      </p>
    </div>

    <div class="row g-4 mb-5">
      <div class="col-md-6 col-xl-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
          <div class="card-body text-center p-4">
            <i class="fa-solid fa-users fs-1 text-primary mb-3"></i>

            <h2 class="fw-bold"><%= totalCustomers %></h2>

            <p class="text-muted mb-0">Total Customers</p>
          </div>
        </div>
      </div>

      <div class="col-md-6 col-xl-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
          <div class="card-body text-center p-4">
            <i class="fa-solid fa-file-contract fs-1 text-success mb-3"></i>

            <h2 class="fw-bold"><%= totalPolicies %></h2>

            <p class="text-muted mb-0">Total Policies</p>
          </div>
        </div>
      </div>

      <div class="col-md-6 col-xl-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
          <div class="card-body text-center p-4">
            <i class="fa-solid fa-comments fs-1 text-warning mb-3"></i>

            <h2 class="fw-bold"><%= pendingConsultations %></h2>

            <p class="text-muted mb-0">Pending Consultations</p>
          </div>
        </div>
      </div>

      <div class="col-md-6 col-xl-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
          <div class="card-body text-center p-4">
            <i class="fa-solid fa-calendar-check fs-1 text-danger mb-3"></i>

            <h2 class="fw-bold">10</h2>

            <p class="text-muted mb-0">Premiums Due</p>
          </div>
        </div>
      </div>
    </div>

    <h3 class="fw-bold mb-4">Quick Actions</h3>

    <div class="row g-4">
      <div class="col-md-6 col-lg-4">
        <a href="/admin/consultations" class="text-decoration-none text-dark">
          <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body text-center p-4">
              <i class="fa-solid fa-comments fs-1 text-warning mb-3"></i>

              <h5 class="fw-bold">Consultation Requests</h5>

              <p class="text-muted mb-0">View and manage customer enquiries.</p>
            </div>
          </div>
        </a>
      </div>

      <div class="col-md-6 col-lg-4">
        <a href="/admin/customers" class="text-decoration-none text-dark">
          <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body text-center p-4">
              <i class="fa-solid fa-users fs-1 text-primary mb-3"></i>

              <h5 class="fw-bold">Customers</h5>

              <p class="text-muted mb-0">
                Add, view and manage policy holders.
              </p>
            </div>
          </div>
        </a>
      </div>

      <div class="col-md-6 col-lg-4">
        <a href="/admin/policies" class="text-decoration-none text-dark">
          <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body text-center p-4">
              <i class="fa-solid fa-file-contract fs-1 text-success mb-3"></i>

              <h5 class="fw-bold">Policies</h5>

              <p class="text-muted mb-0">
                Manage policies and premium details.
              </p>
            </div>
          </div>
        </a>
      </div>

      <div class="col-md-6 col-lg-4">
        <a href="/admin/search" class="text-decoration-none text-dark">
          <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body text-center p-4">
              <i class="fa-solid fa-magnifying-glass fs-1 text-info mb-3"></i>

              <h5 class="fw-bold">Search Database</h5>

              <p class="text-muted mb-0">
                Search customers and policies instantly.
              </p>
            </div>
          </div>
        </a>
      </div>

      <div class="col-md-6 col-lg-4">
        <a href="/admin/premiums/due" class="text-decoration-none text-dark">
          <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body text-center p-4">
              <i class="fa-solid fa-calendar-check fs-1 text-danger mb-3"></i>

              <h5 class="fw-bold">Due Premiums</h5>

              <p class="text-muted mb-0">Track upcoming premium payments.</p>
            </div>
          </div>
        </a>
      </div>

      <div class="col-md-6 col-lg-4">
        <a href="/logout" class="text-decoration-none text-dark">
          <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body text-center p-4">
              <i
                class="fa-solid fa-right-from-bracket fs-1 text-secondary mb-3"
              ></i>

              <h5 class="fw-bold">Logout</h5>

              <p class="text-muted mb-0">Securely sign out of the dashboard.</p>
            </div>
          </div>
        </a>
      </div>
    </div>
  </section>
</body>
