<%layout("layouts/boilerplate.ejs")%>
<body>
  <section class="py-5">
    <div class="text-center mb-5">
      <h1 class="fw-bold">Insurance Calculators</h1>

      <p class="text-muted">Estimate premiums and plan your financial goals.</p>
    </div>

    <div class="row g-4">
      <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100">
          <div class="card-body text-center p-5">
            <h1>💰</h1>

            <h4 class="mt-3">Premium Calculator</h4>

            <p class="text-muted">Estimate your monthly premium.</p>

            <a href="/calculators/premium" class="btn btn-outline-primary">
              Open Calculator
            </a>
          </div>
        </div>
      </div>

      <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100">
          <div class="card-body text-center p-5">
            <h1>👴</h1>

            <h4 class="mt-3">Retirement Calculator</h4>

            <p class="text-muted">Plan for a financially secure retirement.</p>

            <a href="/calculators/retirement" class="btn btn-outline-primary">
              Open Calculator
            </a>
          </div>
        </div>
      </div>

      <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100">
          <div class="card-body text-center p-5">
            <h1>🎓</h1>

            <h4 class="mt-3">Child Education Planner</h4>

            <p class="text-muted">Estimate future education expenses.</p>

            <a href="/calculators/education" class="btn btn-outline-primary">
              Open Calculator
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
