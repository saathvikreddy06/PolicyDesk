<% layout("layouts/boilerplate.ejs") %>
<body>
<section class="py-5">

  <div
    class="d-flex flex-column flex-md-row
           justify-content-between
           align-items-md-center
           mb-5"
  >
    <div>
      <h1 class="fw-bold">
        Policies
      </h1>

      <p class="text-muted mb-0">
        View and manage all policies.
      </p>
    </div>
  </div>

  <div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body text-center p-4">

      <i
        class="fa-solid fa-file-contract
               fs-1 text-success mb-3"
      ></i>

      <h2 class="fw-bold">
        <%= policies.length %>
      </h2>

      <p class="text-muted mb-0">
        Total Policies
      </p>

    </div>
  </div>

  <div class="mb-5">

  <form action="/admin/policies/search" method="GET">

    <div class="row g-2">

      <div class="col-md-3">
        <select
          name="field"
          class="form-select"
          required
        >
          <option value="">
            Search By
          </option>

          <option value="policyNum">
            Policy Number
          </option>

          <option value="policyName">
            Policy Name
          </option>

          <option value="status">
            Status
          </option>

          <option value="mode">
            Premium Mode
          </option>

          <option value="customer">
            Customer Name
          </option>
        </select>
      </div>

      <div class="col-md-7">
        <input
          type="text"
          name="q"
          class="form-control"
          placeholder="Enter search value..."
          required
        >
      </div>

      <div class="col-md-2">
        <button
          class="btn btn-success w-100"
        >
          <i class="fa-solid fa-magnifying-glass me-2"></i>
          Search
        </button>
      </div>

    </div>

  </form>

</div>

  <% if (policies.length === 0) { %>

    <div
      class="card border-0 shadow-sm
             rounded-4 p-5 text-center"
    >

      <i
        class="fa-solid fa-file-circle-xmark
               fs-1 text-muted mb-3"
      ></i>

      <h4>
        No Policies Found
      </h4>

      <p class="text-muted mb-0">
        Policies added for customers will appear here.
      </p>

    </div>

  <% } %>

  <div class="row g-4">

    <% policies.forEach(p => { %>

      <div class="col-md-6 col-lg-4">

        <div
          class="card border-0 shadow-sm
                 rounded-4 h-100"
        >

          <div class="card-body p-4">

            <div
              class="d-flex
                     justify-content-between
                     align-items-center
                     mb-3"
            >

              <h5 class="fw-bold mb-0">
                <%= p.policyName %>
              </h5>

              <span
                class="badge
                <%= p.status === 'Active'
                  ? 'text-bg-success'
                  : p.status === 'Grace Period'
                  ? 'text-bg-warning'
                  : p.status === 'Lapsed'
                  ? 'text-bg-danger'
                  : 'text-bg-secondary' %>"
              >
                <%= p.status %>
              </span>

            </div>

            <p class="mb-2">

              <i
                class="fa-solid fa-hashtag
                       me-2 text-success"
              ></i>

              <%= p.policyNum %>

            </p>

            <p class="mb-2">

              <i
                class="fa-solid fa-user
                       me-2 text-success"
              ></i>

              <%= p.customer.fullName %>

            </p>

            <p class="mb-2">

              <i
                class="fa-solid fa-indian-rupee-sign
                       me-2 text-success"
              ></i>

              <%= p.premium.toLocaleString("en-IN") %>

            </p>

            <p class="mb-4">

              <i
                class="fa-solid fa-calendar-days
                       me-2 text-success"
              ></i>

              Next Premium:
              <%= p.nextPremiumDate
      ? p.nextPremiumDate.toDateString()
      : "Not Set" %>

            </p>

            <div class="d-flex gap-2">

  <a
    href="/admin/policies/<%= p._id %>"
    class="btn btn-outline-success flex-fill"
  >
    View
  </a>

  <a
    href="/admin/policies/<%= p._id %>/edit"
    class="btn btn-dark flex-fill"
  >
    Edit
  </a>

  <form
    action="/admin/policies/<%= p._id %>?_method=DELETE"
    method="POST"
    class="flex-fill"
  >
    <button
      class="btn btn-outline-danger w-100"
      onclick="return confirm('Delete this policy?')"
    >
      Delete
    </button>
  </form>

</div>

          </div>

        </div>

      </div>

    <% }) %>

  </div>

</section>
</body>