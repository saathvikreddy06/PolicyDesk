<%layout("layouts/boilerplate.ejs")%>
<body>
    

<section class="py-5">

  <!-- Heading -->
  <div class="mb-5">
    <h1 class="fw-bold">
      Consultation Requests
    </h1>

    <p class="text-muted">
      View and manage all customer enquiries.
    </p>
  </div>

  <% if (consultations.length === 0) { %>

    <div class="card shadow-sm border-0 rounded-4 p-5 text-center">
      <i class="fa-solid fa-comments fs-1 text-muted mb-3"></i>

      <h4>No Consultation Requests</h4>

      <p class="text-muted mb-0">
        New consultation requests will appear here.
      </p>
    </div>

  <% } else { %>

    <div class="row g-4">

      <% consultations.forEach(c => { %>

        <div class="col-lg-6">

          <div class="card shadow-sm border-0 rounded-4 h-100 <%= c.status === 'Completed' ? 'bg-light' : '' %>">

            <div class="card-body p-4">

              <!-- Header -->
              <div class="d-flex justify-content-between align-items-center mb-4">

                <div>
                  <h4 class="mb-1">
                    <%= c.name %>
                  </h4>

                  <% if (c.createdAt) { %>
                    <small class="text-muted">
                      Submitted on
                      <%= c.createdAt.toDateString() %>
                    </small>
                  <% } %>
                </div>

                <span
                  class="badge fs-6 px-3 py-2
                  <%= c.status === 'Pending'
                    ? 'text-bg-warning'
                    : 'text-bg-success' %>">

                  <%= c.status %>

                </span>

              </div>

              <!-- Details -->

              <p class="mb-2">
                <i class="fa-solid fa-phone me-2 text-primary"></i>
                <%= c.phone %>
              </p>

              <p class="mb-2">
                <i class="fa-solid fa-envelope me-2 text-primary"></i>
                <%= c.email %>
              </p>

              <p class="mb-2">
                <i class="fa-solid fa-briefcase me-2 text-primary"></i>
                <%= c.occupation %>
              </p>

              <p class="mb-4">
                <i class="fa-solid fa-bullseye me-2 text-primary"></i>
                <%= c.purpose %>
              </p>

              <% if (c.message) { %>

                <div class="bg-body-secondary rounded-3 p-3 mb-4">
                  <strong>Message</strong>

                  <p class="text-muted mb-0 mt-2">
                    <%= c.message %>
                  </p>
                </div>

              <% } %>

              <!-- Actions -->

              <div class="d-flex flex-wrap gap-2">

                <a
                  href="tel:<%= c.phone %>"
                  class="btn btn-outline-primary btn-sm"
                >
                  <i class="fa-solid fa-phone me-1"></i>
                  Call
                </a>

                <a
                  href="https://wa.me/91<%= c.phone %>?text=Hello%20<%= c.name %>,%20thank%20you%20for%20your%20interest%20in%20our%20insurance%20services."
                  target="_blank"
                  class="btn btn-success btn-sm"
                >
                  <i class="fa-brands fa-whatsapp me-1"></i>
                  WhatsApp
                </a>

                <% if (c.status === "Pending") { %>

                  <form
                    action="/admin/consultations/<%= c._id %>/complete"
                    method="POST"
                    class="d-inline"
                  >
                    <button class="btn btn-dark btn-sm">
                      <i class="fa-solid fa-check me-1"></i>
                      Mark as Completed
                    </button>
                  </form>

                <% } %>

              </div>

            </div>

          </div>

        </div>

      <% }) %>

    </div>

  <% } %>

</section>
</body>