<% layout("layouts/boilerplate.ejs") %>
<body>
<section class="py-5">

  <div
    class="d-flex flex-column flex-md-row
           justify-content-between
           align-items-md-center mb-5"
  >
    <div>
      <h1 class="fw-bold">
        <%= customer.fullName %>
      </h1>

      <p class="text-muted mb-0">
        Customer Profile
      </p>
    </div>

    <div class="mt-3 mt-md-0">

  <a
    href="/admin/customers/<%= customer._id %>/edit"
    class="btn btn-dark me-2"
  >
    Edit Customer
  </a>

  <a
    href="/admin/customers/<%= customer._id %>/policies/new"
    class="btn btn-primary me-2"
  >
    Add Policy
  </a>

  <form
    action="/admin/customers/<%= customer._id %>?_method=DELETE"
    method="POST"
    class="d-inline"
  >
    <button
      class="btn btn-danger"
      onclick="return confirm('Delete this customer?')"
    >
      Delete
    </button>
  </form>

</div>
  </div>

  <div class="row g-4">

    <div class="col-lg-6">
      <div class="card border-0 shadow-sm rounded-4 h-100">
        <div class="card-body p-4">

          <h4 class="fw-bold mb-4">
            Personal Information
          </h4>

          <p><strong>Father's Name:</strong> <%= customer.fatherName %></p>
          <p><strong>Mother's Name:</strong> <%= customer.motherName %></p>
          <p><strong>Date of Birth:</strong> <%= customer.dob.toDateString() %></p>
          <p><strong>Place of Birth:</strong> <%= customer.pob || "Not Provided" %></p>
          <p><strong>Occupation:</strong> <%= customer.occupation || "Not Provided" %></p>
          <p><strong>Education:</strong> <%= customer.education %></p>
          <p><strong>Height:</strong> <%= customer.height %> cm</p>
          <p class="mb-0">
            <strong>Weight:</strong> <%= customer.weight %> kg
          </p>

        </div>
      </div>
    </div>

    <div class="col-lg-6">
      <div class="card border-0 shadow-sm rounded-4 h-100">
        <div class="card-body p-4">

          <h4 class="fw-bold mb-4">
            Contact Information
          </h4>

          <p><strong>Phone:</strong> <%= customer.phoneNum %></p>
          <p><strong>Email:</strong> <%= customer.email || "Not Provided" %></p>
          <p class="mb-0">
            <strong>Address:</strong>
            <%= customer.address %>
          </p>

        </div>
      </div>
    </div>

    <div class="col-lg-6">
      <div class="card border-0 shadow-sm rounded-4 h-100">
        <div class="card-body p-4">

          <h4 class="fw-bold mb-4">
            Identity & Financial Information
          </h4>

          <p><strong>Aadhaar:</strong> <%= customer.aadharNum || "Not Provided" %></p>
          <p><strong>PAN:</strong> <%= customer.panNum %></p>
          <p class="mb-0">
            <strong>Income:</strong>
            ₹ <%= customer.income.toLocaleString("en-IN") %>
          </p>

        </div>
      </div>
    </div>

    <div class="col-lg-6">
      <div class="card border-0 shadow-sm rounded-4 h-100">
        <div class="card-body p-4">

          <h4 class="fw-bold mb-4">
            Bank Information
          </h4>

          <p><strong>Bank:</strong> <%= customer.bankName %></p>
          <p><strong>Account Number:</strong> <%= customer.bankAccountNum %></p>
          <p><strong>IFSC:</strong> <%= customer.ifscCode %></p>
          <p><strong>MICR:</strong> <%= customer.micr %></p>
          <p class="mb-0">
            <strong>Bank Address:</strong>
            <%= customer.bankAddress %>
          </p>

        </div>
      </div>
    </div>

    <div class="col-12">
      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">

          <h4 class="fw-bold mb-4">
            Nominee Information
          </h4>

          <p><strong>Name:</strong> <%= customer.nominee.name %></p>
          <p class="mb-0">
            <strong>Relation:</strong>
            <%= customer.nominee.relation %>
          </p>

        </div>
      </div>
    </div>

    <div class="col-12">
      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">

          <div
            class="d-flex justify-content-between
                   align-items-center mb-4"
          >
            <h4 class="fw-bold mb-0">
              Policies
            </h4>

            <span class="badge text-bg-primary">
              <%= policies.length %> Policies
            </span>
          </div>

          <% if (policies.length === 0) { %>

            <p class="text-muted mb-0">
              No policies have been added yet.
            </p>

          <% } else { %>

            <div class="row g-3">

              <% policies.forEach(p => { %>

                <div class="col-md-6">

                  <div class="border rounded-4 p-3">

                    <h5 class="fw-bold">
                      <%= p.policyName %>
                    </h5>

                    <p class="mb-2">
                      Policy No:
                      <%= p.policyNum %>
                    </p>

                    <p class="mb-3">
                      Status:
                      <span
                        class="badge text-bg-success"
                      >
                        <%= p.status %>
                      </span>
                    </p>

                    <a
                      href="/admin/policies/<%= p._id %>"
                      class="btn btn-outline-primary btn-sm"
                    >
                      View Policy
                    </a>

                  </div>

                </div>

              <% }) %>

            </div>

          <% } %>

        </div>
      </div>
    </div>

  </div>

</section>
</body>