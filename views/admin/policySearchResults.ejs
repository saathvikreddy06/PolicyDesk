<% layout("layouts/boilerplate.ejs") %>
<body>
<section class="py-5">

  <div class="mb-5">

    <h1 class="fw-bold">
      Search Results
    </h1>

    <p class="text-muted mb-0">
      Results for "<%= q %>"
    </p>

  </div>

  <% if (policies.length === 0) { %>

    <div
      class="card border-0 shadow-sm rounded-4 p-5 text-center"
    >

      <i
        class="fa-solid fa-magnifying-glass fs-1 text-muted mb-3"
      ></i>

      <h4>
        No Policies Found
      </h4>

      <p class="text-muted mb-0">
        Try searching with different details.
      </p>

    </div>

  <% } else { %>

    <div class="row g-4">

      <% policies.forEach(p => { %>

        <div class="col-md-6 col-lg-4">

          <div
            class="card border-0 shadow-sm rounded-4 h-100"
          >

            <div class="card-body p-4">

              <div
                class="d-flex justify-content-between
                       align-items-center mb-3"
              >

                <h5 class="fw-bold mb-0">
                  <%= p.policyName %>
                </h5>

                <span
                  class="badge text-bg-success"
                >
                  <%= p.status %>
                </span>

              </div>

              <p class="mb-2">
                Policy No:
                <%= p.policyNum %>
              </p>

              <p class="mb-2">
                Customer:
                <%= p.customer.fullName %>
              </p>

              <p class="mb-4">
                Premium:
                ₹ <%= p.premium.toLocaleString("en-IN") %>
              </p>

              <a
                href="/admin/policies/<%= p._id %>"
                class="btn btn-outline-success w-100"
              >
                View Policy
              </a>

            </div>

          </div>

        </div>

      <% }) %>

    </div>

  <% } %>

</section>
</body>